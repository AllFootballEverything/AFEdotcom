# ---------------------------------------------------------------------------
# Copy to .env.local for development. In production set these in the Vercel
# project (Settings -> Environment Variables). Never commit real values.
# ---------------------------------------------------------------------------

# --- Site ------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Sanity ----------------------------------------------------------------
# projectId and dataset are public (they ship in the client bundle).
# Without a projectId the site still builds and renders the design defaults,
# but shows no content and the studio reports itself unconfigured.
NEXT_PUBLIC_SANITY_PROJECT_ID=
# Optional — defaults to "production".
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-07-22
# Token with Editor rights. Used server-side only: writing booking enquiries
# and member records, and reading drafts in preview.
SANITY_API_WRITE_TOKEN=
# Shared secret you also paste into the Sanity webhook that revalidates the site.
SANITY_REVALIDATE_SECRET=

# --- Whop ------------------------------------------------------------------
# From the Whop dashboard -> Developer -> your app.
# Client ID looks like app_xxxxxxxx.
WHOP_CLIENT_ID=
WHOP_CLIENT_SECRET=
# API key with member:basic:read (and member:email:read) permissions. Used for
# the membership backfill lookup when a user signs in.
WHOP_API_KEY=
# Your Whop company id (biz_xxxxxxxx) — required by the memberships endpoint.
WHOP_COMPANY_ID=
# Redirect URI registered on the Whop app. Must match exactly, character for
# character, including protocol and trailing path.
WHOP_REDIRECT_URI=http://localhost:3000/api/auth/whop/callback
# Signing secret for the Whop webhook endpoint (starts with whsec_).
WHOP_WEBHOOK_SECRET=

# Map each Whop plan/product id to an AFE tier. Comma-separated id:tier pairs.
# Tiers must be one of: scout | access | elite
WHOP_TIER_MAP=plan_xxxxscout:scout,plan_xxxxaccess:access,plan_xxxxelite:elite

# Public checkout URLs shown on the Members page tier cards.
NEXT_PUBLIC_WHOP_CHECKOUT_SCOUT=
NEXT_PUBLIC_WHOP_CHECKOUT_ACCESS=
NEXT_PUBLIC_WHOP_CHECKOUT_ELITE=

# --- Session ---------------------------------------------------------------
# 32+ random bytes. Generate with: openssl rand -base64 32
SESSION_SECRET=

# --- Stripe (shop) ---------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (booking enquiries) ---------------------------------------------
RESEND_API_KEY=
BOOKING_NOTIFY_TO=team@allfootballeverything.com
BOOKING_NOTIFY_FROM=bookings@allfootballeverything.com
